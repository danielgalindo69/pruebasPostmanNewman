                                                                   "pm.test(\"Status 200 OK\", function () {\r",
                                                                   "    pm.response.to.have.status(200);\r",
                                                                   "});\r",
                                                                   "\r",
                                                                   "pm.test(\"Estructura de Contrato - El resultado debe ser un array de objetos con el formato correcto\", function () {\r",
                                                                   "    const body = pm.response.json();\r",
                                                                   "    pm.expect(body).to.be.an(\"array\");\r",
                                                                   "    \r",
                                                                   "    if(body.length \u003e 0) {\r",
                                                                   "        const primerElemento = body[0];\r",
                                                                   "        pm.expect(primerElemento).to.have.all.keys(\"id\", \"nombre\", \"apellido\", \"numero\");\r",
                                                                   "        pm.expect(primerElemento.id).to.be.a(\"number\");\r",
                                                                   "        pm.expect(primerElemento.nombre).to.be.a(\"string\");\r",
                                                                   "    }\r",
                                                                   "});"
