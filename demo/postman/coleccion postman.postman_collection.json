                 {
                     "name":  "Crear una persona",
                     "event":  [
                                   {
                                       "listen":  "prerequest",
                                       "script":  {
                                                      "exec":  [
                                                                   "const nombreCsv = pm.iterationData.get(\"nombre\");",
                                                                   "const apellidoCsv = pm.iterationData.get(\"apellido\");",
                                                                   "const numeroCsv = pm.iterationData.get(\"numero\");",
                                                                   "",
                                                                   "if (nombreCsv \u0026\u0026 apellidoCsv \u0026\u0026 numeroCsv) {",
                                                                   "    pm.collectionVariables.set(\"tempNombre\", nombreCsv);",
                                                                   "    pm.collectionVariables.set(\"tempApellido\", apellidoCsv);",
                                                                   "    pm.collectionVariables.set(\"tempNumero\", String(numeroCsv));",
                                                                   "} else {",
                                                                   "    const randomSuffix = Math.floor(Math.random() * 900000 + 100000);",
                                                                   "    pm.collectionVariables.set(\"tempNombre\", \"Juan\" + randomSuffix);",
                                                                   "    pm.collectionVariables.set(\"tempApellido\", \"Perez\" + randomSuffix);",
                                                                   "    pm.collectionVariables.set(\"tempNumero\", \"300\" + randomSuffix);",
                                                                   "}"
                                                               ],
                                                      "type":  "text/javascript",
                                                      "packages":  {

                                                                   },
                                                      "requests":  {

                                                                   }
                                                  }
                                   },
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "exec":  [
                                                                   "pm.test(\"Status 201 Created\", function () {",
                                                                   "    pm.response.to.have.status(201);",
                                                                   "});",
                                                                   "",
                                                                   "const body = pm.response.json();",
                                                                   "pm.collectionVariables.set(\"personaId\", body.id);",
                                                                   "",
                                                                   "pm.test(\"La persona creada coincide con los datos enviados\", function () {",
                                                                   "    pm.expect(body.nombre).to.eql(pm.collectionVariables.get(\"tempNombre\"));",
                                                                   "    pm.expect(body.apellido).to.eql(pm.collectionVariables.get(\"tempApellido\"));",
                                                                   "    pm.expect(body.numero).to.eql(pm.collectionVariables.get(\"tempNumero\"));",
                                                                   "});"
                                                               ],
                                                      "type":  "text/javascript",
                                                      "packages":  {

                                                                   },
                                                      "requests":  {

                                                                   }
                                                  }
                                   }
                               ],
