					]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"status 200\", function () {",
							"  pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "Actualizar persona",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"nombre\": \"Juan Carlos\",\n  \"apellido\": \"Perez\",\n  \"numero\": \"3007654321\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/personas/{{personaId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"personas",
