					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"personas"
					]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"status 200\", function () {",
							"  pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "Buscar persona",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/personas/{{personaId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"personas",
